# Streamlit Secrets 設定例
#
# 本番運用（Streamlit Community Cloud）では:
#   https://share.streamlit.io でアプリを選択
#   → Settings → Secrets で以下の内容を貼り付け
#
# ローカル開発で試したい場合:
#   このファイルを secrets.toml にコピーして値を入れる
#   .gitignoreに secrets.toml が含まれていることを確認

# アプリのアクセスパスワード（ベーシック認証）
APP_PASSWORD = "your-password-here"

# Gemini API キー（Maki さんが保有するキー）
GEMINI_API_KEY = "AIza..."
